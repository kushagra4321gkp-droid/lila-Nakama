# Copy to .env and fill in your values before running docker-compose.prod.yml

# Public IP or domain of your cloud VM (e.g. 45.67.89.10 or game.example.com)
NAKAMA_PUBLIC_HOST=YOUR_SERVER_IP_OR_DOMAIN

# Port Nakama listens on (default 7350 — keep unless you changed it)
NAKAMA_PUBLIC_PORT=7350

# Set to "true" if you have TLS/SSL termination in front of Nakama
NAKAMA_SSL=false

# Nakama server key (must match Nakama config — default is "defaultkey")
NAKAMA_SERVER_KEY=defaultkey

# Nakama console credentials
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=changeme_please
